# ============================================================
# 灵感小精灵 / oiioii Muse — gitignore
# 严防 secrets 泄漏 + 减小仓库体积
# ============================================================

# ── Secrets（绝对不能进 git） ─────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
backend/.env
Frontend demo/.env
Frontend demo/.env.local

# ── Python 后端 ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ── Node / 前端 ──────────────────────────────────────────────
node_modules/
Frontend demo/node_modules/
Frontend demo/dist/
Frontend demo/.vite/
.parcel-cache/
.cache/
*.tsbuildinfo

# ── 测试 / 覆盖率 ────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── IDE / OS ─────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ── 项目内部 ────────────────────────────────────────────────
# 优化期间生成的快照 / plan 文件（不影响部署，不必跟仓库走）
*.tar.gz
*.snapshot
.snapshots/
plan.md
plan-bc.md

# 仅作个人备查的旧文档（root 下散落的早期资料）
/AGENT_PROMPT_ARCHITECTURE.md
/NEXT_DEVELOPMENT_PLAN_AND_AGENT_FLOW.md
/TECHNICAL_DEVELOPMENT.md
/漏斗规则
# 旧版 backend 残骸（已合并到 oii muse/backend）
/backend/

# 大体积本地备份（手动 tar 出来的快照目录）
/oii muse.snapshots/

# ── 其它 ────────────────────────────────────────────────────
*.log
logs/
tmp/
