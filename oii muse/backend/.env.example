# AI API 配置（示例文件禁止填写真实 Key；真实值只放 backend/.env）
AI_API_BASE_URL=https://api.example.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# 动态词卡可选快模型配置；留空时复用主 AI 配置
TAG_AI_API_BASE_URL=
TAG_AI_API_KEY=
TAG_AI_MODEL=gpt-4o-mini

# 备用 AI API 配置：仅在主 API 失败、超时或返回异常时使用；不需要时保持为空
FALLBACK_AI_API_BASE_URL=
FALLBACK_AI_API_KEY=
FALLBACK_AI_MODEL=

# 插件鉴权 Token（示例文件禁止填写真实 Token；真实值只放 backend/.env）
APP_TOKEN=

# 限流配置
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=50
